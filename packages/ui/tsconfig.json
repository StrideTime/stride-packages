{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "target": "ES6",
    "jsx": "react-jsx",
    "lib": ["ES2022", "DOM"],
    "typeRoots": ["./node_modules/@types", "./src/types"],
    "baseUrl": ".",
    "paths": {
      "@utils": ["src/utils/index.ts"],
      "@utils/*": ["src/utils/*"],
      "@primitives": ["src/primitives/index.ts"],
      "@primitives/*": ["src/primitives/*"]
    },
  },
  "include": ["src/**/*", ".storybook/**/*"],
  "exclude": ["node_modules", "dist", "coverage"]
}
